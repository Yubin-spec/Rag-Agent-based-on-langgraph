# 本项目禁止调用 OpenAI 自有模型，仅允许：DeepSeek（大模型）、BGE-M3（向量）、BGE Reranker Large（重排）
# LLM：仅 DeepSeek，通过兼容 OpenAI 的 API 调用
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_API_KEY=your_deepseek_api_key
# 多 Key / 多 endpoint 负载均衡（可选）：base_url|api_key|weight|name，多项可逗号分隔
# DEEPSEEK_API_ENDPOINTS=https://api.deepseek.com/v1|key_a|2|primary,https://api.deepseek.com/v1|key_b|1|backup
# DEEPSEEK_CIRCUIT_BREAKER_FAILURES=3
# DEEPSEEK_CIRCUIT_BREAKER_OPEN_SECONDS=30

# Embedding / Reranker：均为本地部署/本地加载，不调用远程 API；可为 HuggingFace 名或本地模型路径
BGE_EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
BGE_RERANKER_MODEL=BAAI/bge-reranker-large

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=kb_chunks

# DB for Text2SQL (example)
TEXT2SQL_DATABASE_URI=sqlite:///./data/kb.db

# PostgreSQL 探活：每分钟连接一次保持数据库在线（可选，为空则不探活）
# POSTGRESQL_KEEPALIVE_URI=postgresql://user:pass@host:5432/dbname
# POSTGRESQL_KEEPALIVE_INTERVAL_SECONDS=60

# 对话长期记忆：历史落 PostgreSQL，进程重启后可恢复（可选，为空则仅内存）
# CHAT_HISTORY_POSTGRESQL_URI=postgresql://user:pass@host:5432/dbname
# 长期记忆：加载时只取最近 N 条注入短期记忆，0 全量；写入时单条 content 最大字符数，0 不截断
# CHAT_HISTORY_LOAD_MAX_MESSAGES=0
# CHAT_HISTORY_MAX_CONTENT_CHARS=0
# 长期记忆：true 时使用 asyncpg 异步读写（需安装 asyncpg），不占线程池
# CHAT_HISTORY_USE_ASYNCPG=false
# 短期记忆：PostgreSQL checkpointer URL；为空则不启用（支持跨进程 interrupt 后 resume）
# CHAT_CHECKPOINTER_POSTGRESQL_URI=
# 短期记忆：Redis checkpointer URL（需 Redis 8+ 或 Redis Stack，含 RedisJSON/RediSearch）；为空则进程内 MemorySaver
# CHAT_CHECKPOINTER_REDIS_URL=
# 问答监控与反馈分析：为空时默认复用 CHAT_HISTORY_POSTGRESQL_URI
# QA_MONITORING_POSTGRESQL_URI=postgresql://user:pass@host:5432/dbname

# 对话与上下文（可选）
# MAX_CONVERSATION_TURNS=15
# LLM_CONTEXT_WINDOW_TURNS=10
# LLM_CONTEXT_SUMMARIZE_OLD=true   # 将窗口外旧对话压缩为摘要后一并喂给大模型，避免早期信息丢失
# 单条消息字符上限（节省上下文）：历史轮每条、当前轮用户消息；0 表示不截断
# LLM_CONTEXT_MAX_CHARS_PER_MESSAGE_OLD=600
# LLM_CONTEXT_MAX_CHARS_PER_MESSAGE_LATEST=0
# 旧对话摘要时送入 LLM 的对话文本最大字符数，0 不限制（默认 8000）
# LLM_CONTEXT_SUMMARY_INPUT_MAX_CHARS=8000

# RAG 抗幻觉与上下文（可选）
# RAG_MAX_CONTEXT_CHARS=0   # 注入生成的检索上下文总字符上限，0 不限制

# RAG 抗幻觉（可选）
# RAG_ANSWER_GROUNDING_MIN_SCORE=0.18
# RAG_ANSWER_MAX_REGENERATE_TIMES=3

# 异常与人工介入（可选）
# AGENT_REQUEST_TIMEOUT_SECONDS=120
# AGENT_LLM_RETRY_TIMES=2
# AGENT_NEED_HUMAN_REPLY=当前服务暂时异常，请稍后重试或转人工客服。

# 异步高并发：to_thread 使用的线程池 max_workers；0 为 Python 默认
# ASYNCIO_THREAD_POOL_WORKERS=0
# 生产多进程：Uvicorn worker 数；仅在不使用 reload 时生效（RELOAD=0 或 Docker），默认 1。多 worker 时建议负载均衡做会话保持
# UVICORN_WORKERS=1
# API 全局限流：同时处理的请求数上限，0 不限制；超限排队等待
# API_MAX_CONCURRENT_REQUESTS=0
# 优雅关闭：SIGTERM 后等待进行中请求完成的秒数
# GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30
# 会话锁：同一 thread_id 串行化，避免并发写冲突；false 关闭锁（仅单用户/单会话可关）
# CONVERSATION_LOCK_ENABLED=true
# CONVERSATION_LOCK_BUCKETS=1024   # 锁分桶数，thread_id 哈希取模

# 问答缓存（Redis，可选）
# REDIS_URL=redis://localhost:6379/0
# ANSWER_CACHE_TTL_SECONDS=86400
# ANSWER_CACHE_ENABLED=true
# ANSWER_CACHE_MAX_VALUE_BYTES=0   # 单条答案最大缓存字节，0 不限制
# 热 key：进程内 LRU 条数，0 关闭；防击穿单飞锁分桶数（建议 256～1024）
# ANSWER_CACHE_LOCAL_MAX_ENTRIES=0
# ANSWER_CACHE_LOCAL_TTL_SECONDS=60
# ANSWER_CACHE_SINGLE_FLIGHT_BUCKETS=256
# REDIS_MAX_CONNECTIONS=10
# REDIS_SOCKET_CONNECT_TIMEOUT=2
# REDIS_SOCKET_TIMEOUT=5
# REDIS_HEALTH_CHECK_INTERVAL=30
# Redis 哨兵（可选）：两者均配置时通过 Sentinel 获取 master，忽略 REDIS_URL 直连
# REDIS_SENTINEL_SERVICE_NAME=mymaster
# REDIS_SENTINEL_NODES=127.0.0.1:26379,127.0.0.1:26380
# 多 worker 共享状态：配置后解析缓存、待确认 SQL、人工中断状态存 Redis，多进程共享
# SHARED_STATE_REDIS_URL=redis://localhost:6379/1

# MinerU 文档解析（本地部署版）：本地起 MinerU 服务后填写地址；为空则使用占位解析（仅文本+切块）
# MINERU_API_URL=http://127.0.0.1:8001
# MINERU_API_TOKEN=
# 并发：同时调用 MinerU API 的最大数量，超出时排队（默认 5）
# MINERU_CONCURRENCY_LIMIT=5
# MinerU 单次请求超时（秒，默认 120）
# MINERU_TIMEOUT_SECONDS=120
# MinerU 请求失败时重试次数（5xx/超时/连接错误），0 不重试
# MINERU_RETRY_TIMES=2

# 数据库连接池与熔断（可选）
# POSTGRESQL_POOL_SIZE=5
# POSTGRESQL_MAX_OVERFLOW=10
# POSTGRESQL_POOL_TIMEOUT=10
# POSTGRESQL_STATEMENT_TIMEOUT_MS=0   # 单条 SQL 超时（毫秒），0 不限制
# DB_CIRCUIT_BREAKER_THRESHOLD=5
# DB_CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# RAG 检索缓存：进程内 LRU 条数，0 关闭；TTL 秒数
# RAG_RETRIEVAL_CACHE_MAX_ENTRIES=0
# RAG_RETRIEVAL_CACHE_TTL_SECONDS=300
